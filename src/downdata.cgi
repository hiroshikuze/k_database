if(length($form{'loadfile'})>0) {
	require 'file_access_lib.pl';
	
	chomp($form{'loadfile'});
	@data=&file_access("<$form{'loadfile'}",1);
	
	if($error_code==0) {
		#魹ｽﾇ｡魹ｽ魹ｽ魹ｽ魹ｽﾑｴ魹ｽ
		for($i=0;$i<=$#data;$i++) {
			&jcode::convert(¥$data[$i], "sjis", "euc"); 
			$data[$i]=‾ s/,/$comma/g;
			$data[$i]=‾ s/¥t/,/g;
		}
		$data[0]="";
		
		#魹ｽﾇ｡魹ｽ魹ｽﾇ｡魹ｽ魹ｽ魹ｽ魹ｽ庿ｵ｡魹ｽ魹ｽﾐ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽPC魹ｽ魹ｽ魹ｽﾏ､魹ｽ
		print "Content-type: application/octet-stream; name=".$form{'loadfile'}."¥n¥n";
		print "@data";
	} else {
		#魹ｽﾕ･魹ｽ魹ｽ魹ｽ魹ｽ槶ｬ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾉ､ﾇ､魹ｽ魹ｽﾊ､魹ｽ
		$error_message_name="魹ｽﾕ･魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ'".$form{'loadfile'}."'魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾉ､ﾇ､魹ｽ魹ｽﾞ､魹ｽ魹ｽ魹ｽ";
	}
} else {
	#index.cgi魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ隍ｿ魹ｽ魹ｽ魹ｽ魹ｽ html 魹ｽﾇｰ魹ｽﾆｰ魹ｽ魹ｽﾇｧ
